# IMPORTANT: Do NOT commit a real .env file to Git.
# All environment variables below should be added directly to Vercel's
# Environment Variables dashboard (Project Settings > Environment Variables).

# === REQUIRED FOR CORE FUNCTIONALITY ===

# GEMINI_API_KEY: Required for Gemini AI API calls (chat, agents, RAG).
GEMINI_API_KEY=

# Firebase Web SDK Config (publicly safe — restricted by Firebase Auth domain).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK (server-only — service account JSON, base64-encoded preferred).
# Required for: /api/admin/* routes, server-side Firestore writes, task persistence.
FIREBASE_SERVICE_ACCOUNT_KEY=

# Public app URL — used for OG metadata and absolute links.
NEXT_PUBLIC_APP_URL=https://kalmeron.app

# === ADMIN GOVERNANCE ===
# Comma-separated list of admin emails allowed to access /admin and /api/admin/*.
ADMIN_EMAILS=

# === COST CONTROL ===
# Daily cost cap (USD). Alerts at 80%, automatic throttle at 100%.
COST_DAILY_LIMIT_USD=50
HIGH_LATENCY_MS=8000
LOW_SUCCESS_PCT=90

# === OPTIONAL ===
# Billing & monetization
OPENMETER_API_KEY=
OPENMETER_BASE_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
