# Kalmeron Two — Environment Variables (example)
# Copy to .env.local for development; in production set via the hosting platform.
# Never commit real values.

# ───────────────── Firebase (client) ─────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ───────────────── Firebase Admin (server) ─────────────────
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ───────────────── Google AI / Gemini ─────────────────
GOOGLE_GENERATIVE_AI_API_KEY=

# ───────────────── Stripe (P0-1) ─────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs — naming: STRIPE_PRICE_<PLAN>_<CYCLE>_<CURRENCY>
# PLAN ∈ STARTER | GROWTH | SCALE | FINANCE_CREW
# CYCLE ∈ MONTHLY | YEARLY
# CURRENCY ∈ EGP | USD
STRIPE_PRICE_STARTER_MONTHLY_EGP=
STRIPE_PRICE_STARTER_YEARLY_EGP=
STRIPE_PRICE_GROWTH_MONTHLY_EGP=
STRIPE_PRICE_GROWTH_YEARLY_EGP=
STRIPE_PRICE_SCALE_MONTHLY_EGP=
STRIPE_PRICE_SCALE_YEARLY_EGP=
STRIPE_PRICE_STARTER_MONTHLY_USD=
STRIPE_PRICE_STARTER_YEARLY_USD=
STRIPE_PRICE_GROWTH_MONTHLY_USD=
STRIPE_PRICE_GROWTH_YEARLY_USD=
STRIPE_PRICE_SCALE_MONTHLY_USD=
STRIPE_PRICE_SCALE_YEARLY_USD=
STRIPE_PRICE_FINANCE_CREW_MONTHLY_USD=

# ───────────────── Sentry (Observability) ─────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ───────────────── Python sidecars (services/) ─────────────────
# URL of the Arabic PDF worker (services/pdf-worker). Defaults to
# http://localhost:5004 in development. Point this to your Cloud Run /
# Railway / Fly URL in production.
PDF_WORKER_URL=http://localhost:8000
# Hard upload ceiling (bytes) enforced by the worker itself. Defaults to 20MB.
PDF_WORKER_MAX_BYTES=20971520
# Comma-separated CORS origins for the worker. Use the Vercel URL in prod.
PDF_WORKER_CORS=*

# Egyptian tax/legal calculator (services/egypt-calc, port 8008).
EGYPT_CALC_URL=http://localhost:8008

# LLM-as-judge evaluator (services/llm-judge, port 8080).
# When GEMINI_API_KEY is set the judge uses real LLM scoring; otherwise it
# returns deterministic stub scores. Set both to enable real-mode in CI.
LLM_JUDGE_URL=http://localhost:8080
JUDGE_MODEL=gemini-2.5-flash-lite

# Local multilingual embeddings (services/embeddings-worker, port 8099).
EMBEDDINGS_WORKER_URL=http://localhost:8099
# Default = 384-dim multilingual ONNX model (~220MB, supports Arabic + 50 langs).
# Other supported options: sentence-transformers/paraphrase-multilingual-mpnet-base-v2 (768d, 1GB),
# intfloat/multilingual-e5-large (1024d, 2.2GB).
EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDINGS_CACHE_SIZE=1000

# Data warehouse (services/data-warehouse). DuckDB locally; switch profile
# to BigQuery in production. No URL — `npm run dw:build` runs the full pipeline.

# ───────────────── Cron (P2 SLO + restore drill) ─────────────────
CRON_SECRET=

# ───────────────── App URLs ─────────────────
NEXT_PUBLIC_APP_URL=http://localhost:5000
NEXT_PUBLIC_BASE_URL=http://localhost:5000

# ───────────────── Council toggle (set to 'off' in tests) ─────────────────
KALMERON_COUNCIL=
