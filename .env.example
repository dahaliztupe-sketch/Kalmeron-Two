# Kalmeron Two — Environment Variables (example)
# Copy to .env.local for development; in production set via the hosting platform.
# Never commit real values.

# ───────────────── Firebase (client) ─────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ───────────────── Firebase Admin (server) ─────────────────
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ───────────────── Multi-Provider LLM Stack ─────────────────
# Providers are tried in order (override via KALMERON_PROVIDER_ORDER).
# Default: gemini → openrouter → groq → anthropic → openai.
# Free tiers (OpenRouter :free models, Groq, Gemini Studio) cost $0.
#
# Google Gemini (free Studio key works; preferred for Arabic).
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_API_KEY=
# OpenRouter — single key gives access to 200+ models (incl. Llama, DeepSeek,
# Claude, GPT). Free tier: ~20 req/min on `:free` model variants.
OPENROUTER_API_KEY=
# Groq — extremely fast (300+ tok/s) Llama inference. Free tier rate-limited.
GROQ_API_KEY=
# Anthropic / OpenAI direct (paid only — used last in fallback chain).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Override the fallback order, e.g. KALMERON_PROVIDER_ORDER=groq,gemini,openrouter
KALMERON_PROVIDER_ORDER=
# Per-model monthly USD caps (JSON map). Example:
# MODEL_BUDGETS={"anthropic/claude-opus-4.5":5,"openai":25}
MODEL_BUDGETS=
# Semantic-cache tuning (opt-in via ctx.cache=true on a call).
LLM_CACHE_SIM_THRESHOLD=0.95
LLM_CACHE_CAPACITY=500
LLM_CACHE_TTL_MS=1800000
EMBEDDINGS_URL=http://localhost:8099

# ───────────────── Stripe (P0-1) ─────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs — naming: STRIPE_PRICE_<PLAN>_<CYCLE>_<CURRENCY>
# PLAN ∈ STARTER | PRO | FOUNDER  (matches src/lib/billing/plans.ts)
# CYCLE ∈ MONTHLY | ANNUAL
# CURRENCY ∈ EGP | USD
STRIPE_PRICE_STARTER_MONTHLY_EGP=
STRIPE_PRICE_STARTER_ANNUAL_EGP=
STRIPE_PRICE_STARTER_MONTHLY_USD=
STRIPE_PRICE_STARTER_ANNUAL_USD=
STRIPE_PRICE_PRO_MONTHLY_EGP=
STRIPE_PRICE_PRO_ANNUAL_EGP=
STRIPE_PRICE_PRO_MONTHLY_USD=
STRIPE_PRICE_PRO_ANNUAL_USD=
STRIPE_PRICE_FOUNDER_MONTHLY_EGP=
STRIPE_PRICE_FOUNDER_ANNUAL_EGP=
STRIPE_PRICE_FOUNDER_MONTHLY_USD=
STRIPE_PRICE_FOUNDER_ANNUAL_USD=

# ───────────────── Fawry Pay (Egyptian local payments) ─────────────────
# Sandbox: https://atfawry.fawrystaging.com  ·  Prod: https://www.atfawry.com
FAWRY_BASE_URL=https://atfawry.fawrystaging.com
FAWRY_MERCHANT_CODE=
FAWRY_SECURITY_KEY=
FAWRY_PUBLIC_BASE_URL=https://kalmeron.com

# ───────────────── Resend (transactional email + daily brief) ─────────────────
RESEND_API_KEY=
EMAIL_FROM=Kalmeron <noreply@kalmeron.com>

# ───────────────── Platform admins (comma-separated Firebase UIDs) ─────────────────
PLATFORM_ADMIN_UIDS=

# ───────────────── Sentry (Observability) ─────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ───────────────── Python sidecars (services/) ─────────────────
# URL of the Arabic PDF worker (services/pdf-worker). Defaults to
# http://localhost:5004 in development. Point this to your Cloud Run /
# Railway / Fly URL in production.
PDF_WORKER_URL=http://localhost:8000
# Hard upload ceiling (bytes) enforced by the worker itself. Defaults to 20MB.
PDF_WORKER_MAX_BYTES=20971520
# Comma-separated CORS origins for the worker. Use the Vercel URL in prod.
PDF_WORKER_CORS=*

# Egyptian tax/legal calculator (services/egypt-calc, port 8008).
EGYPT_CALC_URL=http://localhost:8008

# LLM-as-judge evaluator (services/llm-judge, port 8080).
# When GEMINI_API_KEY is set the judge uses real LLM scoring; otherwise it
# returns deterministic stub scores. Set both to enable real-mode in CI.
LLM_JUDGE_URL=http://localhost:8080
JUDGE_MODEL=gemini-2.5-flash-lite

# Local multilingual embeddings (services/embeddings-worker, port 8099).
EMBEDDINGS_WORKER_URL=http://localhost:8099
# Default = 384-dim multilingual ONNX model (~220MB, supports Arabic + 50 langs).
# Other supported options: sentence-transformers/paraphrase-multilingual-mpnet-base-v2 (768d, 1GB),
# intfloat/multilingual-e5-large (1024d, 2.2GB).
EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDINGS_CACHE_SIZE=1000

# Data warehouse (services/data-warehouse). DuckDB locally; switch profile
# to BigQuery in production. No URL — `npm run dw:build` runs the full pipeline.

# ───────────────── Cron (P2 SLO + restore drill) ─────────────────
CRON_SECRET=

# ───────────────── App URLs ─────────────────
NEXT_PUBLIC_APP_URL=http://localhost:5000
NEXT_PUBLIC_BASE_URL=http://localhost:5000

# ───────────────── Council toggle (set to 'off' in tests) ─────────────────
KALMERON_COUNCIL=
