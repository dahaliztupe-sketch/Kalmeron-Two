modules = ["nodejs-20", "python-3.12", "web"]
[agent]
expertMode = true
stack = "GAMESTACK_JS"

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "libxcrypt", "openssl"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PDF Worker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Embeddings Worker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Egypt Calc"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LLM Judge"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "PDF Worker"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/pdf-worker && ([ ! -d .venv ] && uv venv .venv >/dev/null 2>&1 && source .venv/bin/activate && uv pip install -q -r requirements.txt >/dev/null 2>&1; source .venv/bin/activate && uvicorn main:app --host 0.0.0.0 --port 8000 --log-level info)"
waitForPort = 8000

[[workflows.workflow]]
name = "Embeddings Worker"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/embeddings-worker && ([ ! -d .venv ] && uv venv .venv >/dev/null 2>&1 && source .venv/bin/activate && uv pip install -q -r requirements.txt >/dev/null 2>&1; source .venv/bin/activate && uvicorn main:app --host 0.0.0.0 --port 8099 --log-level info)"
waitForPort = 8099

[[workflows.workflow]]
name = "Egypt Calc"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/egypt-calc && [ ! -d .venv ] && uv venv .venv >/dev/null 2>&1 && source .venv/bin/activate && uv pip install -q -r requirements.txt >/dev/null 2>&1; source .venv/bin/activate && uvicorn main:app --host 0.0.0.0 --port 8008 --log-level info"
waitForPort = 8008

[[workflows.workflow]]
name = "LLM Judge"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/llm-judge && ([ ! -d .venv ] && uv venv .venv >/dev/null 2>&1 && source .venv/bin/activate && uv pip install -q -r requirements.txt >/dev/null 2>&1; source .venv/bin/activate && uvicorn main:app --host 0.0.0.0 --port 8080 --log-level info)"
waitForPort = 8080

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5006
externalPort = 3000

[[ports]]
localPort = 5007
externalPort = 4200

[[ports]]
localPort = 5008
externalPort = 5000

[[ports]]
localPort = 5009
externalPort = 5173

[[ports]]
localPort = 5010
externalPort = 3001

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[userenv]

[userenv.shared]
NEXT_PUBLIC_FIREBASE_API_KEY = "AIzaSy8RRcFPp2YwhQYawPvs9pUckwmCKcXzQhW"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN = "kalmeron-two.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID = "kalmeron-two"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET = "kalmeron-two.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID = "686711690176"
NEXT_PUBLIC_FIREBASE_APP_ID = "1:686711690176:web:aef254de2ec4ea357ee25"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID = "G-GLX7PM8VCE"
MODEL_PRO = "gemini-2.5-pro"
KALMERON_COUNCIL = "on"

[deployment]
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]

[postMerge]
path = ".local/scripts/post_merge_setup.sh"
timeoutMs = 180000
