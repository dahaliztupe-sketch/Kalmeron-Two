modules = ["nodejs-20", "python-3.12", "web"]
[agent]
expertMode = true
stack = "GAMESTACK_JS"
integrations = ["javascript_gemini_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "libxcrypt", "openssl"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PDF Worker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Embeddings Worker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Egypt Calc"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LLM Judge"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && cp -rn node_modules/@swc/helpers/cjs node_modules/next/node_modules/@swc/helpers/cjs 2>/dev/null; npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "PDF Worker"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/pdf-worker && ([ ! -d .venv ] && uv venv .venv >/dev/null 2>&1 && source .venv/bin/activate && uv pip install -q -r requirements.txt >/dev/null 2>&1; source .venv/bin/activate && uvicorn main:app --host 0.0.0.0 --port 8000 --log-level info)"
waitForPort = 8000

[[workflows.workflow]]
name = "Embeddings Worker"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/embeddings-worker && ([ ! -d .venv ] && uv venv .venv >/dev/null 2>&1 && source .venv/bin/activate && uv pip install -q -r requirements.txt >/dev/null 2>&1; source .venv/bin/activate && uvicorn main:app --host 0.0.0.0 --port 8099 --log-level info)"
waitForPort = 8099

[[workflows.workflow]]
name = "Egypt Calc"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/egypt-calc && [ ! -d .venv ] && uv venv .venv >/dev/null 2>&1 && source .venv/bin/activate && uv pip install -q -r requirements.txt >/dev/null 2>&1; source .venv/bin/activate && uvicorn main:app --host 0.0.0.0 --port 8008 --log-level info"
waitForPort = 8008

[[workflows.workflow]]
name = "LLM Judge"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/llm-judge && ([ ! -d .venv ] && uv venv .venv >/dev/null 2>&1 && source .venv/bin/activate && uv pip install -q -r requirements.txt >/dev/null 2>&1; source .venv/bin/activate && uvicorn main:app --host 0.0.0.0 --port 8080 --log-level info)"
waitForPort = 8080

