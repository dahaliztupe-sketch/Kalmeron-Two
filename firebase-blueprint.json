{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "createdAt"]
    },
    "Idea": {
      "title": "Idea",
      "description": "Startup idea validation data",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "feedback": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "createdAt", "updatedAt"]
    },
    "BusinessPlan": {
      "title": "Business Plan",
      "description": "Structured business plan",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "createdAt", "updatedAt"]
    },
    "Thread": {
      "title": "Thread",
      "description": "Chat thread between user and AI",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model", "system"] },
        "text": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["role", "text", "createdAt"]
    },
    "ChatHistory": {
      "title": "Chat History",
      "description": "Persisted chat history for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "messages": { "type": "array", "items": { "$ref": "#/entities/Message" } },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "required": ["userId", "messages", "created_at", "updated_at"]
    },
    "UserMemory": {
      "title": "User Memory",
      "description": "Stored intelligence about user interaction history",
      "type": "object",
      "properties": {
        "summary": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["summary", "updatedAt"]
    },
    "Task": {
      "title": "Task",
      "description": "Task management data",
      "type": "object",
      "properties": {
        "taskId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "failed", "awaiting_human"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "createdBy": { "type": "string" },
        "assignee": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "dueDate": { "type": "string" },
        "parentTaskId": { "type": "string" },
        "workflowId": { "type": "string" }
      },
      "required": ["taskId", "name", "description", "status", "priority", "createdBy", "assignee", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles. Top-level."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "User tasks."
    },
    "/users/{userId}/memory": {
      "schema": { "$ref": "#/entities/UserMemory" },
      "description": "User's long-term memory."
    },
    "/users/{userId}/chat_history/{chatId}": {
      "schema": { "$ref": "#/entities/ChatHistory" },
      "description": "User's chat histories."
    },
    "/users/{userId}/ideas/{ideaId}": {
      "schema": { "$ref": "#/entities/Idea" },
      "description": "User's ideas."
    },
    "/users/{userId}/businessPlans/{planId}": {
      "schema": { "$ref": "#/entities/BusinessPlan" },
      "description": "User's business plans."
    },
    "/users/{userId}/threads/{threadId}": {
      "schema": { "$ref": "#/entities/Thread" },
      "description": "User's chat threads."
    },
    "/users/{userId}/threads/{threadId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages within a chat thread."
    },
    "/users/{userId}/memories/{memoryId}": {
      "schema": { "$ref": "#/entities/UserMemory" },
      "description": "User's session memories."
    },
    "/user_credits/{userId}": {
      "schema": {
        "title": "CreditWallet",
        "description": "User credit wallet and usage limits",
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "dailyBalance": { "type": "number" },
          "monthlyBalance": { "type": "number" },
          "lifetimeEarned": { "type": "number" },
          "lifetimeConsumed": { "type": "number" },
          "dailyLimit": { "type": "number" },
          "monthlyLimit": { "type": "number" },
          "dailyResetAt": { "type": "string" },
          "monthlyResetAt": { "type": "string" },
          "rolledOverCredits": { "type": "number" },
          "lastUpdated": { "type": "string" }
        },
        "required": ["userId", "dailyBalance", "monthlyBalance", "dailyLimit", "monthlyLimit"]
      },
      "description": "User's credits and limits management."
    },
    "/credit_transactions/{transactionId}": {
      "schema": {
        "title": "CreditTransaction",
        "description": "Log of credit usage and accumulation",
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "type": { "type": "string" },
          "amount": { "type": "number" },
          "source": { "type": "string" },
          "agentName": { "type": "string" },
          "modelUsed": { "type": "string" },
          "tokensConsumed": { "type": "number" },
          "costCents": { "type": "number" },
          "timestamp": { "type": "string" },
          "remainingDaily": { "type": "number" },
          "remainingMonthly": { "type": "number" }
        },
        "required": ["userId", "type", "amount", "timestamp"]
      },
      "description": "History of credit transactions."
    },
    "/knowledge_base/{docId}": {
      "schema": {
        "title": "KnowledgeBase",
        "description": "RAG Knowledge base",
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "embedding": { "type": "array" },
          "category": { "type": "string" },
          "createdAt": { "type": "string" }
        },
        "required": ["text", "embedding", "createdAt"]
      },
      "description": "RAG internal knowledge."
    }
  }
}
