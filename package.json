{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5000 -H 0.0.0.0",
    "dev:turbo": "next dev --turbopack -p 5000 -H 0.0.0.0",
    "typecheck": "node --stack-size=32768 --max-old-space-size=8192 ./node_modules/typescript/bin/tsc --noEmit",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start -p 5000 -H 0.0.0.0",
    "lint": "eslint .",
    "lint:py": "ruff check services/ && ruff format --check services/",
    "format:py": "ruff format services/",
    "typecheck:py": "mypy services/pdf-worker services/egypt-calc services/llm-judge services/embeddings-worker",
    "codegen:openapi": "node scripts/generate-openapi.mjs",
    "codegen:clients": "node scripts/generate-api-clients.mjs",
    "codegen": "npm run codegen:openapi && npm run codegen:clients",
    "clean": "next clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:rules": "vitest run test/firestore-rules.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "eval": "tsx test/eval/run-eval.ts",
    "eval:models": "tsx scripts/eval-models.ts",
    "eval:report": "tsx test/eval/run-eval.ts --json && python3 services/eval-analyzer/analyze.py",
    "eval:promptfoo": "npx --yes promptfoo@latest eval --config test/eval/promptfoo/promptfooconfig.yaml --output test/eval/promptfoo/results.json",
    "qa:kitab": "python3 scripts/qa/run_kitab_bench.py",
    "data:egypt-legal": "python3 scripts/data/fetch_egypt_legal_corpus.py --out data/egypt-legal",
    "diag": "node scripts/diagnostics/run-all.mjs",
    "diag:errors": "node scripts/diagnostics/scan-errors.mjs",
    "diag:gaps": "node scripts/diagnostics/scan-gaps.mjs",
    "qa": "bash -c 'source qa/setup-env.sh && tsx qa/index.ts'",
    "qa:smoke": "bash -c 'source qa/setup-env.sh && QA_DEVICES=desktop_std QA_PAGES=smoke tsx qa/index.ts'",
    "qa:fast": "bash -c 'source qa/setup-env.sh && QA_DEVICES=desktop_std,iphone tsx qa/index.ts'",
    "qa:full": "bash -c 'source qa/setup-env.sh && QA_DEVICES=all tsx qa/index.ts'",
    "lint:lexicon": "tsx scripts/lexicon-lint.ts",
    "verify:backup": "tsx scripts/verify-backup.ts",
    "pdf-worker:dev": "cd services/pdf-worker && uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "egypt-calc:dev": "cd services/egypt-calc && uvicorn main:app --host 0.0.0.0 --port 8008 --reload",
    "egypt-calc:test": "cd services/egypt-calc && python -m pytest tests/ -q",
    "llm-judge:dev": "cd services/llm-judge && uvicorn main:app --host 0.0.0.0 --port 8080 --reload",
    "embeddings-worker:dev": "cd services/embeddings-worker && uvicorn main:app --host 0.0.0.0 --port 8099 --reload",
    "dw:build": "cd services/data-warehouse && dbt build --profiles-dir .",
    "dw:test": "cd services/data-warehouse && dbt test --profiles-dir .",
    "dw:query": "cd services/data-warehouse && python -c \"import duckdb,sys; print(duckdb.connect('dev.duckdb',read_only=True).execute(sys.argv[1]).fetchdf().to_string())\"",
    "firebase:login": "firebase login",
    "firebase:emulators": "firebase emulators:start",
    "firebase:deploy": "firebase deploy --only firestore",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules",
    "firebase:deploy:indexes": "firebase deploy --only firestore:indexes",
    "audit": "tsx audit/runner.ts",
    "audit:fast": "QA_MODULES=security,authentication,frontend,storage,accessibility,i18n,benchmarks tsx audit/runner.ts",
    "audit:security": "QA_MODULES=security tsx audit/runner.ts",
    "audit:auth": "QA_MODULES=authentication tsx audit/runner.ts",
    "audit:frontend": "QA_MODULES=frontend tsx audit/runner.ts",
    "audit:backend": "QA_MODULES=backend tsx audit/runner.ts",
    "audit:storage": "QA_MODULES=storage tsx audit/runner.ts",
    "audit:performance": "QA_MODULES=performance tsx audit/runner.ts",
    "audit:seo": "QA_MODULES=seo tsx audit/runner.ts",
    "audit:agents": "QA_MODULES=ai-agents tsx audit/runner.ts",
    "audit:business": "QA_MODULES=business tsx audit/runner.ts",
    "audit:a11y": "QA_MODULES=accessibility tsx audit/runner.ts",
    "audit:i18n": "QA_MODULES=i18n tsx audit/runner.ts",
    "audit:obs": "QA_MODULES=observability tsx audit/runner.ts",
    "audit:test": "QA_MODULES=testing tsx audit/runner.ts",
    "audit:devops": "QA_MODULES=devops tsx audit/runner.ts",
    "audit:docs": "QA_MODULES=documentation tsx audit/runner.ts",
    "audit:payments": "QA_MODULES=payments tsx audit/runner.ts",
    "audit:pwa": "QA_MODULES=pwa-mobile tsx audit/runner.ts",
    "audit:privacy": "QA_MODULES=data-privacy tsx audit/runner.ts",
    "audit:benchmarks": "QA_MODULES=benchmarks tsx audit/runner.ts",
    "audit:compare": "QA_MODULES=benchmarks tsx audit/runner.ts",
    "audit:ci": "QA_BASE_URL=http://localhost:5000 QA_FAIL_ON_CRITICAL=true tsx audit/runner.ts",
    "precommit": "npm run typecheck && npm run lint && npm run audit:fast"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.52",
    "@ai-sdk/anthropic": "^3.0.72",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/groq": "^3.0.36",
    "@ai-sdk/openai": "^3.0.54",
    "@ai-sdk/react": "^3.0.170",
    "@base-ui/react": "^1.4.1",
    "@fontsource/cairo": "^5.2.7",
    "@google/genai": "^1.51.0",
    "@langchain/core": "^1.1.41",
    "@langchain/langgraph": "^1.2.9",
    "@mastra/core": "^1.28.0",
    "@mlc-ai/web-llm": "^0.2.82",
    "@next/bundle-analyzer": "^16.2.4",
    "@openmeter/sdk": "^1.0.0-beta.227",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@playwright/test": "^1.59.1",
    "@react-email/components": "^1.0.12",
    "@react-pdf/renderer": "^4.5.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@sentry/nextjs": "^10.50.0",
    "@tanstack/query-sync-storage-persister": "^5.100.5",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-query-persist-client": "^5.100.5",
    "@temporalio/client": "^1.16.1",
    "@temporalio/workflow": "^1.16.1",
    "@testing-library/react": "^16.3.2",
    "@traceloop/node-server-sdk": "^0.26.0",
    "@tthbfo2/firebase-cost-trimmer": "^1.0.2",
    "@types/pdfkit": "^0.17.6",
    "@vercel/edge-config": "^1.4.3",
    "@vercel/flags": "^3.1.1",
    "@vitejs/plugin-react": "^6.0.1",
    "ai": "^6.0.168",
    "ai-sdk-cost": "^1.5.0",
    "arabic-reshaper": "^1.1.0",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "date-fns": "^4.1.0",
    "drizzle-zod": "^0.8.3",
    "exceljs": "^4.4.0",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "geist": "^1.7.0",
    "jose": "^6.2.2",
    "langfuse": "^3.38.20",
    "lucide-react": "^1.11.0",
    "mathjs": "^15.2.0",
    "mem0ai": "^3.0.1",
    "motion": "^12.38.0",
    "neo4j-driver": "^6.0.1",
    "next": "^16.2.4",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "p-limit": "^7.3.0",
    "p-retry": "^8.0.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.12",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "vitest": "^4.1.4",
    "web-vitals": "^5.2.0",
    "xss": "^1.0.15",
    "zod": "^4.4.2",
    "zod-validation-error": "^5.0.0"
  },
  "overrides": {
    "@qdrant/js-client-rest": "1.17.0",
    "undici": "^6.23.0",
    "eslint": "^9.39.4",
    "axios": "^1.15.2",
    "uuid": "^14.0.0",
    "@tootallnate/once": "^3.0.1",
    "postcss": "^8.5.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.3",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "firebase-tools": "^15.16.0",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.2.3",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3"
  }
}
