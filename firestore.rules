rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isVerified() {
      // Ensure the user email is verified to prevent spoofing
      return request.auth.token.email_verified == true;
    }

    // Users Collection (Strict Separation of PII)
    match /users/{userId} {
      // Only the user can read or write their own general profile
      allow read, update: if isOwner(userId);
      // Ensure creation forces ID match
      allow create: if isOwner(userId) && request.resource.data.keys().hasAll(['email']);
      
      // PII subcollection (Address, Phone, strictly isolated)
      match /private/info {
        allow read, write: if isOwner(userId);
      }
    }

    // Ideas / Projects
    match /ideas/{ideaId} {
      // Users can only query/list their own ideas
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['ideaDescription', 'userId'])
                    && request.resource.data.ideaDescription is string
                    && request.resource.data.ideaDescription.size() <= 10000;
                    
      // Prevent ownership hijacking during update
      allow update: if isSignedIn() 
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId;
                    
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // WebAuthn Passkeys data
    match /passkeys/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Billing Logic (Immutable via client)
    match /user_credits/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // System-only updates via CreditManager (Admin SDK)
    }

    match /credit_transactions/{transactionId} {
      // Users can only view their own transactions, no bulk reads without filter
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false; // System-only logs
    }
  }
}
