{
  "$schema": "https://railway.app/railway.schema.json",
  "_comment": "Railway monorepo config — each service is a separate Railway service in the same project.",
  "services": [
    {
      "name": "kalmeron-pdf-worker",
      "build": { "builder": "DOCKERFILE", "dockerfilePath": "services/pdf-worker/Dockerfile", "dockerContext": "services/pdf-worker" },
      "deploy": { "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT --workers 2", "healthcheckPath": "/health", "healthcheckTimeout": 30, "restartPolicyType": "ON_FAILURE", "restartPolicyMaxRetries": 3 }
    },
    {
      "name": "kalmeron-egypt-calc",
      "build": { "builder": "DOCKERFILE", "dockerfilePath": "services/egypt-calc/Dockerfile", "dockerContext": "services/egypt-calc" },
      "deploy": { "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT --workers 2", "healthcheckPath": "/health", "healthcheckTimeout": 30 }
    },
    {
      "name": "kalmeron-llm-judge",
      "build": { "builder": "DOCKERFILE", "dockerfilePath": "services/llm-judge/Dockerfile", "dockerContext": "services/llm-judge" },
      "deploy": { "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT --workers 2", "healthcheckPath": "/health", "healthcheckTimeout": 30 }
    },
    {
      "name": "kalmeron-embeddings-worker",
      "build": { "builder": "DOCKERFILE", "dockerfilePath": "services/embeddings-worker/Dockerfile", "dockerContext": "services/embeddings-worker" },
      "deploy": { "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT --workers 1", "healthcheckPath": "/health", "healthcheckTimeout": 60 }
    }
  ]
}
